<section class="block block-newsletter">

  <div class="newsletter-wrapper container-fluid px-0 bg-primary"  style="background-image: url('https://www.medesy.it/site/wp-content/uploads/2023/04/Medesy_Corporate_039-1-1-scaled.jpg');" >

    <div class="newsletter-content container">
            <h2 class="text-white">News e novità</h2>
      
            <h3 class="text-white"><p style="text-align: center;">Iscriviti alla nostra Newsletter<br />
per ricevere tutti gli aggiornamenti sulle ultime novità e iniziative MEDESY!</p>
</h3>
      
            
      <button type="button" class="btn-newsletter btn rounded-pill mt-4 btn-red" data-bs-toggle="modal" data-bs-target="#modal-newsletter">Iscriviti!</button>

      <div id="modal-newsletter" class="modal" tabindex="-2">
        <div class="modal-dialog modal-xl modal-dialog-centered">
          <div class="modal-content bg-primary text-start">
            <div class="modal-header border-0">
              <h4 class="modal-title text-white">Newsletter</h4>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body gform-primary">
              
                <div class='gf_browser_chrome gform_wrapper gravity-theme gform-theme--no-framework' data-form-theme='gravity-theme' data-form-index='0' id='gform_wrapper_3' ><div id='gf_3' class='gform_anchor' tabindex='-1'></div>
                        <div class='gform_heading'>
